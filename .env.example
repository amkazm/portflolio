# ---- Database ----
# SQLite (local dev, zero setup)
DATABASE_URL="file:./dev.db"
# To switch to PostgreSQL (e.g. Neon/Supabase), set provider="postgresql" in
# prisma/schema.prisma and use a URL like:
# DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"

# ---- Auth (NextAuth) ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---- Admin seed account ----
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-strong-password"

# ---- Contact email (Resend) — optional ----
RESEND_API_KEY=""
CONTACT_TO_EMAIL="am.kazempour@gmail.com"

# ---- Public site URL (for SEO/sitemap) ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
